{"id":"1037","label":"hoverResult","result":{"contents":[{"language":"dart","value":"dart:convert"},{"language":"dart","value":"class JsonEncoder extends Converter<Object, String>"},{"language":"dart","value":"/// This class converts JSON objects to strings.\n///\n/// Example:\n///\n/// ```dart\n/// const JsonEncoder encoder = JsonEncoder();\n/// const data = {'text': 'foo', 'value': '2'};\n///\n/// final String jsonString = encoder.convert(data);\n/// print(jsonString); // {\"text\":\"foo\",\"value\":\"2\"}\n/// ```\n///\n/// Example of pretty-printed output:\n///\n/// ```dart\n/// const JsonEncoder encoder = JsonEncoder.withIndent('  ');\n///\n/// const data = {'text': 'foo', 'value': '2'};\n/// final String jsonString = encoder.convert(data);\n/// print(jsonString);\n/// // {\n/// //   \"text\": \"foo\",\n/// //   \"value\": \"2\"\n/// // }\n/// ```"}]},"type":"vertex"}
{"-----Comment":"Done emitting imported declaration","id":"1038","label":"","type":"vertex"}
{"-----Comment":"Emitting imported reference to [JsonEncoder]","id":"1039","label":"","type":"vertex"}
